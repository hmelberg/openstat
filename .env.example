# Anthropic API key for dataminimering Edge Function
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Tilgangsnøkkel - delt streng som brukere må lime inn i m2py for å bruke AI-vurderingen
M2PY_ACCESS_TOKEN=

# (Gammel - kan fjernes når M2_T2 er deployet)
# M2PY_ALLOWED_ORIGINS=http://localhost:8888
